  "probability": {
    "display": "Probability",
    "emoji": "🎲",
    "keywords": ["probability", "probabilities"],
    "formulas": [
      { "name": "Basic probability", "formula": "P(A) = n(A) / n(S), where S = sample space" },
      { "name": "Complement", "formula": "P(A') = 1 - P(A)" },
      { "name": "Union of events", "formula": "P(A ∪ B) = P(A) + P(B) - P(A ∩ B)" },
      { "name": "Mutually exclusive", "formula": "P(A ∩ B) = 0, so P(A ∪ B) = P(A) + P(B)" },
      { "name": "Independent events", "formula": "P(A ∩ B) = P(A) × P(B)" },
      { "name": "Conditional probability", "formula": "P(A|B) = P(A ∩ B) / P(B)" },
      { "name": "Expected value", "formula": "E(X) = Σ x × P(X = x)" },
      { "name": "Probability range", "formula": "0 ≤ P(A) ≤ 1" }
    ]
  },
