      { "name": "Sum of cubes", "formula": "a³ + b³ = (a + b)(a² - ab + b²)" },
      { "name": "Difference of cubes", "formula": "a³ - b³ = (a - b)(a² + ab + b²)" },
      { "name": "Factor theorem", "formula": "If P(a) = 0, then (x - a) is a factor of P(x)" },
      { "name": "Remainder theorem", "formula": "When P(x) is divided by (x - a), remainder = P(a)" }
    ]
